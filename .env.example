# Google Apps Script web app deployment URL (ends in /exec)
# https://script.google.com/macros/s/.../exec
VITE_FORM_SUBMIT_URL=

# Optional: must match Script property SUBMIT_SECRET in Apps Script (mild abuse friction only; visible in client bundle)
# VITE_FORM_SUBMIT_SECRET=

# GitHub Actions: add repository secrets VITE_FORM_SUBMIT_URL and optional VITE_FORM_SUBMIT_SECRET
# (Settings → Secrets and variables → Actions) so the Pages deploy workflow can build with the form URL.
